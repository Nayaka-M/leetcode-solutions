class Solution {
    public void moveZeroes(int[] nums) {
        int left=0;
        int right=nums.length-1;
        for(int i=0;i<=nums.length-1;i++)
        {
            if(nums[i]!=0)
            {
        int temp=0;
        temp=nums[i];
        nums[i]=nums[left];
        nums[left]=temp;
        left++;
        
            }
        }
    }
}

  
