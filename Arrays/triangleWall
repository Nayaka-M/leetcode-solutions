class Solution {
    public static void triangleWall(int s) {

        for(int i = 1; i <= s; i++) {
            for(int j = 1; j <= i; j++) {
                System.out.print("*");
                if(j < i) {   // space only between stars
                    System.out.print(" ");
                }
            }
            System.out.println();
        }
    }
}




